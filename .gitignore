# ---------------------------------------------------------------------------
# Repository hygiene for the open-vocabulary detection / tracking research repo.
#
# Tracked:   docs, scripts, manifests, metadata, notes, checksums, environment
#            notes, READMEs, directory placeholders, upstream submodule pointers
#            (commit SHAs), AND the curated literature-collection paper PDFs.
# Untracked: model weights, datasets, inference outputs, caches.
#
# NOTE: The paper PDFs under papers/ are intentionally COMMITTED as part of the
# curated Grounding DINO literature collection (they are small, redistributable
# academic PDFs from official sources such as arXiv / CVF). This is a deliberate
# change from the earlier "PDFs by-link only" policy; see
# docs/organization_log.md. Model weights and datasets remain untracked.
# ---------------------------------------------------------------------------

# --- Upstream source ------------------------------------------------------
# third_party/* are Git submodules: only the commit pointer is tracked here.
third_party/*/.git/

# --- Model weights --------------------------------------------------------
# Ignore everything under checkpoints/ except the directory skeleton and docs.
checkpoints/**
!checkpoints/**/
!checkpoints/**/.gitkeep
!checkpoints/**/*.md

# --- Datasets -------------------------------------------------------------
# Ignore all dataset payloads; keep READMEs / manual download instructions.
datasets/**
!datasets/**/
!datasets/**/.gitkeep
!datasets/**/*.md
# Small derived metadata (counts, image manifests) IS tracked: it is text, it is
# what makes the dataset state inspectable without shipping the payload, and it
# lets anyone see exactly which VisDrone images RefDrone needs. Image/archive
# payloads stay ignored by the rules above and by *.zip / *.part below.
!datasets/**/metadata/*.json

# --- Papers ---------------------------------------------------------------
# The curated literature collection under papers/ IS committed (PDFs + notes).
# Only guard against accidental junk landing there.
papers/**/*.part
papers/**/*.tmp
papers/**/*.crdownload

# --- Inference / experiment outputs ---------------------------------------
outputs/**
!outputs/.gitkeep

# --- Vendored upstream dependency files copied into environments/ ---------
# (these are explicitly force-added; see environments/*/upstream/)

# --- Model / engine / archive artifacts anywhere ---------------------------
*.engine
*.plan
*.onnx
*.pt
*.pth
*.ckpt
*.safetensors
*.bin
*.tar
*.tar.gz
*.tgz
*.zip
*.part

# --- Python / env ---------------------------------------------------------
__pycache__/
*.py[cod]
.venv/
venv/
.env
*.egg-info/
*.tmp

# --- Editors --------------------------------------------------------------
.idea/
.vscode/

# --- OS -------------------------------------------------------------------
.DS_Store
Thumbs.db

# --- Grounded SAM 2 local evaluation (experiments/) ---------------------------
# Generated outputs and environments are never committed; scripts, configs,
# small JSON/CSV results and the summary ARE.
experiments/**/outputs/**
!experiments/**/outputs/**/.gitkeep
experiments/**/inputs/**
!experiments/**/inputs/**/.gitkeep
.venv-grounded-sam2/
*.mp4
*.avi
*.mov
*.mkv
*.npy
*.npz
build/
*.so
.venv-gsam2-cuda/

# --- Offline Grounding DINO + SAM 2 video annotation (annotate_video.py) ------
# The short KITTI demo clip and its annotated result ARE committed (~3.5 MB each)
# as the deliverable of the offline pipeline; the blanket *.mp4 rule above would
# otherwise drop them. Everything else the pipeline generates stays untracked.
!artifacts/demo_input.mp4
!artifacts/demo_annotated.mp4

# Local bert-base-uncased for Grounding DINO's text encoder: weights are large and
# redistributable from HF, so the directory is never committed (checkpoints/** and
# *.safetensors already cover it; named here so the intent is explicit).
checkpoints/bert-base-uncased/

# Temporary extracted-frame directories. annotate_video.py uses tempfile.
# TemporaryDirectory, but the upstream demos write these into the working dir.
custom_video_frames/
tracking_results/
*_frames/
